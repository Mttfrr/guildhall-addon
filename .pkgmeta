# BigWigsMods packager config. Without this file, the packager:
#   1. Uses the REPO name ("guildhall-addon") as the addon folder
#      inside the built zip — WoW expects the folder to match the
#      TOC filename (GuildHall.toc → GuildHall/), so the addon
#      wouldn't load and Wago's fingerprinting fails on the
#      mismatch. The package-as directive fixes that.
#   2. Includes every file that isn't in its tiny default ignore
#      list — so .github/, scripts/, spec/, docs/, .luacheckrc,
#      etc. all ship inside the addon folder. WoW tries to load
#      spec/*.lua (which require busted, doesn't exist in-game)
#      and the addon bloats by ~5x. The ignore list below
#      restricts the package to actual addon files.
#
# Docs: https://github.com/BigWigsMods/packager/wiki

package-as: GuildHall

# Repo-only artefacts that don't belong in the user-facing zip.
ignore:
  - .github
  - .luacheckrc
  - scripts
  - spec
  - docs
  - types.lua
  - README.md
  # CHANGELOG.md is kept — Wago/CurseForge display it as the
  # release notes when the user views the addon's listing.

# Use CHANGELOG.md as the per-release changelog instead of letting
# the packager auto-generate one from commit messages. Keeps the
# Wago/CurseForge "What's new" section in lockstep with the file
# the project actually maintains.
manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown
